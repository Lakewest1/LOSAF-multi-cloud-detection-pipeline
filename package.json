    "normalizer": "ts-node normalization/event-normalizer.ts",
    "mapper": "ts-node mitre/attack-mapper.ts",
    "detector": "ts-node detections/detector.ts",
    "demo": "ts-node demo/attack-scenario.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
