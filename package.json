  "description": "Linux Open Security Automation Framework - Cloud-native threat detection and automated response",
  "main": "api/server.ts",
  "type": "commonjs",
  "scripts": {
    "start": "ts-node api/server.ts",
    "dev": "nodemon --exec ts-node api/server.ts",
    "collector:aws": "ts-node collectors/aws/cloudtrail.ts",
