    "aws-sdk": "^1.18.0",
    "axios": "^1.16.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "isomorphic-fetch": "^3.0.0",
    "lucide-react": "^1.24.0",
    "nodemailer": "^9.0.3",
